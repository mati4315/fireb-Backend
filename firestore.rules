rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol
        : null;
    }

    function isSuperAdminEmail() {
      return isSignedIn() && request.auth.token.email == 'matias4315@gmail.com';
    }

    function isSuperAdminUid() {
      return isSignedIn() && request.auth.uid == 'Z4f5ogXDQaNhEY4iBf9jgkPnQMP2';
    }

    function isAdmin() {
      return isSuperAdminEmail() ||
        isSuperAdminUid() ||
        (isSignedIn() && request.auth.token.admin == true) ||
        (isSignedIn() && request.auth.token.superAdmin == true) ||
        (isSignedIn() && request.auth.token.super_admin == true) ||
        (userRole() in ['admin', 'administrador', 'super_admin', 'superadmin', 'super admin']);
    }

    function isStaff() {
      return isAdmin() || userRole() == 'colaborador';
    }

    function isValidContent(data) {
      return data.titulo.size() > 0 &&
             data.titulo.size() <= 300 &&
             (data.descripcion.size() <= 5000 || !('descripcion' in data)) &&
             (!('images' in data) || data.images.size() <= 6) &&
             (!('imagesV2' in data) || data.imagesV2.size() <= 6);
    }

    function isValidCommunityPostCreate(data) {
      return isSignedIn() &&
             isValidContent(data) &&
             data.userId == request.auth.uid &&
             data.module == 'community' &&
             data.type == 'post' &&
             data.source == 'user' &&
             data.deletedAt == null &&
             (!('isOficial' in data) || data.isOficial == false) &&
             ('stats' in data) &&
             data.stats.likesCount == 0 &&
             data.stats.commentsCount == 0 &&
             data.stats.viewsCount == 0;
    }

    function isValidCommunityPostUpdate() {
      return isSignedIn() &&
             request.auth.uid == resource.data.userId &&
             resource.data.module == 'community' &&
             request.resource.data.userId == resource.data.userId &&
             request.resource.data.module == 'community' &&
             request.resource.data.type == 'post' &&
             request.resource.data.source == resource.data.source &&
             (!('isOficial' in request.resource.data) || request.resource.data.isOficial == false);
    }

    function isValidAdEventCreate(data) {
      return isSignedIn() &&
             data.adId is string &&
             data.adId.size() > 0 &&
             data.adId.size() <= 120 &&
             data.eventType is string &&
             data.eventType in ['impression', 'click'] &&
             data.count is int &&
             data.count >= 1 &&
             data.count <= 10 &&
             data.sessionId is string &&
             data.sessionId.size() > 0 &&
             data.sessionId.size() <= 120 &&
             data.userId == request.auth.uid &&
             (!('tab' in data) || (data.tab is string && data.tab in ['todo', 'news', 'post'])) &&
             (!('clientAt' in data) || data.clientAt is string);
    }

    function modulesConfigExists() {
      return exists(/databases/$(database)/documents/_config/modules);
    }

    function modulesConfig() {
      return modulesConfigExists()
        ? get(/databases/$(database)/documents/_config/modules).data
        : null;
    }

    function commentsEnabled() {
      return !modulesConfigExists() ||
        !('comments' in modulesConfig()) ||
        !('enabled' in modulesConfig().comments) ||
        modulesConfig().comments.enabled == true;
    }

    function commentsNewsEnabled() {
      return !modulesConfigExists() ||
        !('comments' in modulesConfig()) ||
        !('newsEnabled' in modulesConfig().comments) ||
        modulesConfig().comments.newsEnabled == true;
    }

    function commentsCommunityEnabled() {
      return !modulesConfigExists() ||
        !('comments' in modulesConfig()) ||
        !('communityEnabled' in modulesConfig().comments) ||
        modulesConfig().comments.communityEnabled == true;
    }

    function isCommentsModuleAllowed(moduleName) {
      return commentsEnabled() && (
        (moduleName == 'news' && commentsNewsEnabled()) ||
        (moduleName == 'community' && commentsCommunityEnabled())
      );
    }

    function contentPath(contentId) {
      return /databases/$(database)/documents/content/$(contentId);
    }

    function isContentAvailableForComments(contentId, moduleName) {
      return exists(contentPath(contentId)) &&
        get(contentPath(contentId)).data.deletedAt == null &&
        (
          get(contentPath(contentId)).data.module == moduleName ||
          (moduleName == 'community' && get(contentPath(contentId)).data.type == 'post') ||
          (moduleName == 'news' && get(contentPath(contentId)).data.type == 'news')
        );
    }

    function isValidCommentText(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() <= 500;
    }

    function isValidReplyText(data) {
      return data.text is string && data.text.size() > 0 && data.text.size() <= 300;
    }

    function isValidCommentCreate(data, contentId) {
      return isSignedIn() &&
        data.userId is string &&
        data.userId == request.auth.uid &&
        data.userName is string &&
        data.userName.size() > 0 &&
        data.userName.size() <= 120 &&
        (!('userProfilePicUrl' in data) || data.userProfilePicUrl is string) &&
        isValidCommentText(data) &&
        data.module in ['news', 'community'] &&
        data.contentId == contentId &&
        data.deletedAt == null &&
        data.isEdited == false &&
        ('stats' in data) &&
        data.stats.repliesCount is int &&
        data.stats.repliesCount == 0 &&
        isCommentsModuleAllowed(data.module) &&
        isContentAvailableForComments(contentId, data.module);
    }

    function isCommentEditor() {
      return isSignedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
    }

    function isValidCommentUpdate(contentId) {
      return isCommentEditor() &&
        resource.data.contentId == contentId &&
        request.resource.data.contentId == resource.data.contentId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.module == resource.data.module &&
        request.resource.data.createdAt == resource.data.createdAt &&
        (
          (!('stats' in resource.data) && !('stats' in request.resource.data)) ||
          (
            ('stats' in resource.data) &&
            ('stats' in request.resource.data) &&
            request.resource.data.stats.repliesCount == resource.data.stats.repliesCount
          )
        ) &&
        request.resource.data.userName is string &&
        request.resource.data.userName.size() > 0 &&
        request.resource.data.userName.size() <= 120 &&
        (!('userProfilePicUrl' in request.resource.data) || request.resource.data.userProfilePicUrl is string) &&
        isValidCommentText(request.resource.data);
    }

    function parentCommentPath(contentId, commentId) {
      return /databases/$(database)/documents/content/$(contentId)/comments/$(commentId);
    }

    function isParentCommentAvailable(contentId, commentId, moduleName) {
      return exists(parentCommentPath(contentId, commentId)) &&
        get(parentCommentPath(contentId, commentId)).data.deletedAt == null &&
        (
          !('module' in get(parentCommentPath(contentId, commentId)).data) ||
          get(parentCommentPath(contentId, commentId)).data.module == moduleName
        );
    }

    function isValidReplyCreate(data, contentId, commentId) {
      return isSignedIn() &&
        data.userId is string &&
        data.userId == request.auth.uid &&
        data.userName is string &&
        data.userName.size() > 0 &&
        data.userName.size() <= 120 &&
        (!('userProfilePicUrl' in data) || data.userProfilePicUrl is string) &&
        isValidReplyText(data) &&
        data.module in ['news', 'community'] &&
        data.contentId == contentId &&
        data.commentId == commentId &&
        data.deletedAt == null &&
        data.isEdited == false &&
        isCommentsModuleAllowed(data.module) &&
        isContentAvailableForComments(contentId, data.module) &&
        isParentCommentAvailable(contentId, commentId, data.module);
    }

    function isReplyEditor() {
      return isSignedIn() && (isAdmin() || request.auth.uid == resource.data.userId);
    }

    function isValidReplyUpdate(contentId, commentId) {
      return isReplyEditor() &&
        request.resource.data.contentId == resource.data.contentId &&
        request.resource.data.commentId == resource.data.commentId &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.module == resource.data.module &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.userName is string &&
        request.resource.data.userName.size() > 0 &&
        request.resource.data.userName.size() <= 120 &&
        (!('userProfilePicUrl' in request.resource.data) || request.resource.data.userProfilePicUrl is string) &&
        request.resource.data.contentId == contentId &&
        request.resource.data.commentId == commentId &&
        isValidReplyText(request.resource.data);
    }

    function canWriteModulesConfig() {
      return isStaff() && (
        isAdmin() ||
        !('comments' in request.resource.data) ||
        !('comments' in resource.data) ||
        request.resource.data.comments == resource.data.comments
      );
    }

    // Users: private read, self write
    match /users/{userId} {
      allow read: if request.auth.uid == userId || isAdmin();
      allow write: if request.auth.uid == userId && !('rol' in request.resource.data);
    }

    // Content module
    match /content/{contentId} {
      allow read: if true;
      allow create: if isValidCommunityPostCreate(request.resource.data);
      allow update: if isValidCommunityPostUpdate();
      allow delete: if isAdmin();

      match /likes/{likeUserId} {
        allow read: if true;
        allow create: if request.auth.uid == likeUserId;
        allow delete: if request.auth.uid == likeUserId;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isValidCommentCreate(request.resource.data, contentId);
        allow update: if isValidCommentUpdate(contentId);
        allow delete: if false;

        match /replies/{replyId} {
          allow read: if true;
          allow create: if isValidReplyCreate(request.resource.data, contentId, commentId);
          allow update: if isValidReplyUpdate(contentId, commentId);
          allow delete: if false;
        }
      }
    }

    // Relationships
    match /relationships/{userId} {
      match /followers/{followerId} {
        allow read: if true;
        allow create: if request.auth.uid == followerId;
        allow delete: if request.auth.uid == followerId || isAdmin();
      }

      match /following/{followingId} {
        allow read: if true;
        allow create: if request.auth.uid == userId;
        allow delete: if request.auth.uid == userId || isAdmin();
      }
    }

    // Ads module
    match /ads/{adId} {
      allow read: if (resource.data.active == true) || isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isStaff();
    }

    match /ad_events/{eventId} {
      allow create: if isValidAdEventCreate(request.resource.data);
      allow read: if isStaff();
      allow update: if false;
      allow delete: if isStaff();
    }

    // Surveys module
    match /surveys/{surveyId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    match /survey_votes/{voteId} {
      allow read: if isStaff() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create, update, delete: if false;
    }

    // Sync control (admin only)
    match /_sync_control/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /_config/modules {
      allow read: if true;
      allow create: if isStaff() &&
        (isAdmin() || !('comments' in request.resource.data));
      allow update: if canWriteModulesConfig();
      allow delete: if isStaff();
    }

    // Configuration and feature flags
    match /_config/{document=**} {
      allow read: if true;
      allow write: if isStaff() && document != 'modules';
      allow delete: if isStaff() && document != 'modules';
    }
  }
}
